# ─────────────────────────────────────────────
# Vaultify — Environment Configuration
# Copy this file to .env and fill in values:
#   cp .env.example .env
# ─────────────────────────────────────────────

# REQUIRED — Generate a strong secret:
#   openssl rand -base64 48
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_base64_48

# The URL your frontend is served from.
# Use your domain/IP when deploying publicly, e.g.:
#   FRONTEND_URL=https://vault.yourdomain.com
FRONTEND_URL=http://localhost

# Port to expose the app on (default 80)
PORT=80

# Session duration in hours before the vault auto-locks (default 8)
SESSION_HOURS=8

# Auto-lock on inactivity (minutes) — enforced client-side
# Set in frontend environment or keep default of 15 minutes
VITE_LOCK_MINUTES=15
